{
  "name": "agent-harness",
  "version": "0.1.0",
  "description": "Multi-agent harness for long-running app development: Planner(Pi) → Generator(Claude Code) → Evaluator(Pi)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-harness": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agent",
    "harness",
    "claude-code",
    "pi",
    "multi-agent",
    "orchestration"
  ],
  "author": "DongDongBear",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DongDongBear/agent-harness.git"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "commander": "^14.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}
